# ============================================================
# Specentra AMS — Backend Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Database (MySQL) ---
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql+pymysql://specentra:Specentra@2024@localhost:3306/specentra

# --- JWT Security ---
# IMPORTANT: Change this to a random 32+ character string before going live
SECRET_KEY=specentra-change-this-secret-key-min-32-chars-in-production
ALGORITHM=HS256
# Session duration in minutes (480 = 8 hours, per NFR-015)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- File Storage ---
# On-premise path where uploaded WPs are stored (NFR-016)
FILE_STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=100

# --- Application ---
APP_NAME=Specentra AMS
APP_VERSION=1.0.0
DEBUG=false

# --- CORS (Frontend URLs allowed to call the API) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://YOUR-SERVER-IP

# --- Compliance ---
# 7-year retention enforced (DEC-007, NFR-029)
RETENTION_YEARS=7
