# Railway backend variables
# Set these in the Railway Backend service Variables tab.

DATABASE_URL=mysql+pymysql://${{MySQL.MYSQLUSER}}:${{MySQL.MYSQLPASSWORD}}@${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}

SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

FILE_STORAGE_PATH=/app/uploads
MAX_FILE_SIZE_MB=100

APP_NAME=Specentra AMS
APP_VERSION=1.0.0
DEBUG=false

PUBLIC_BACKEND_URL=https://your-backend-service.up.railway.app
ALLOWED_ORIGINS=https://your-frontend-service.up.railway.app
DOCUMENT_EDITOR_URL=

RETENTION_YEARS=7
